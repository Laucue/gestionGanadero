@using Logic
@using Model
@inject NavigationManager NavManager

<h3>Crear Registro de Auditoría</h3>

<EditForm Model="objAuditLog" OnValidSubmit="SaveAuditLog" FormName="FrmAuditLog">
    <div>
        <label>Usuario:</label>
        <InputSelect @bind-Value="objAuditLog.IdUser">
            <option value="">Seleccione</option>
            @if (users != null)
            {
                @foreach (var user in users)
                {
                    <option value="@user.IdUser">@user.FullName</option>
                }
            }
        </InputSelect>
    </div>
    <div>
        <label>Acción:</label>
        <InputText @bind-Value="objAuditLog.Action" />
    </div>
    <div>
        <label>Entidad:</label>
        <InputText @bind-Value="objAuditLog.Entity" />
    </div>
    <div>
        <label>ID de Entidad:</label>
        <InputNumber @bind-Value="objAuditLog.EntityId" />
    </div>
    <div>
        <label>Detalles:</label>
        <InputTextArea @bind-Value="objAuditLog.Details" />
    </div>
    <button type="submit">Guardar</button>
</EditForm>

@if (successMessage != null)
{
    <div>@successMessage</div>
}

@code {
    // Instancia del registro de auditoría que se está creando
    ActivityLogEntity objAuditLog = new ActivityLogEntity();
    
    // Mensaje para indicar el resultado de la operación
    private string? successMessage;
    
    // Lista de usuarios disponibles para seleccionar
    List<UsersEntity> users = new List<UsersEntity>();
    
    /*
     * Método que se ejecuta al inicializar el componente.
     * Carga la lista de usuarios de forma asíncrona.
     */
    protected override async Task OnInitializedAsync()
    {
        // Carga asíncrona de usuarios
        users = await Task.Run(() => UsersLog.UserList());
        objAuditLog.Timestamp = DateTime.UtcNow;
    }
    
    /*
     * Método que se ejecuta al enviar el formulario.
     * Guarda el registro de auditoría en la base de datos.
     */
    private void SaveAuditLog()
    {
        try
        {
            // Llama al método para crear un registro de auditoría en la capa lógica
            ActivityLogLog.CreateAuditLog(objAuditLog);
            // Muestra un mensaje de éxito
            successMessage = "El registro de auditoría se guardó exitosamente!";
            
            // Reinicia el formulario para un nuevo registro
            objAuditLog = new ActivityLogEntity();
            objAuditLog.Timestamp = DateTime.UtcNow;
        }
        catch (Exception ex)
        {
            // Muestra el mensaje de error en caso de excepción
            successMessage = $"Error al guardar el registro de auditoría: {ex.Message}";
        }
    }
}