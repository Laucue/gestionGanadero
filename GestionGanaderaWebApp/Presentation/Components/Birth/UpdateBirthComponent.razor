@using Logic
@using Model
@inject NavigationManager NavManager

<h3>Actualizar Birth</h3>

<EditForm Model="obj" OnValidSubmit="Update" FormName="FrmBirth">
    <div>
        <label>Madre (Animal):</label>
        <InputSelect @bind-Value="obj.IdMother">
            <option value="">Seleccione</option>
            @if (animals != null)
            {
                @foreach (var a in animals)
                {
                    <option value="@a.IdAnimal">@a.EarringCode</option>
                }
            }
        </InputSelect>
    </div>
    <div>
        <label>Fecha de nacimiento:</label>
        <InputDate @bind-Value="obj.BirthDate" />
    </div>
    <div>
        <label>Número de crías:</label>
        <InputNumber @bind-Value="obj.NumberOfOffspring" />
    </div>
    <button type="submit">Actualizar</button>
</EditForm>

@if (successMessage != null)
{
    <div>@successMessage</div>
}

@code {
    BirthsEntity obj = new BirthsEntity();
    private string? successMessage;
    List<AnimalsEntity> animals = new List<AnimalsEntity>();
    [Parameter] public int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        animals = await Task.Run(() => AnimalsLog.AnimalList());
        var list = await Task.Run(() => BirthsLog.BirthList());
        obj = list.FirstOrDefault(x => x.IdBirth == Id) ?? new BirthsEntity();
    }

    private void Update()
    {
        try
        {
            BirthsLog.UpdateBirth(obj);
            successMessage = $"El parto se actualizó exitosamente!";
            NavManager.NavigateTo("birth/list");
        }
        catch (Exception ex)
        {
            successMessage = $"Error al actualizar el parto: {ex.Message}";
        }
    }
}
