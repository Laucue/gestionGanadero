@using Logic
@using Model
@inject NavigationManager NavManager

<h3>Actualizar Rol</h3>

<EditForm Model="objRole" OnValidSubmit="UpdateRole" FormName="FrmRole">
    <div>
        <label>Nombre:</label>
        <InputText @bind-Value="objRole.Name" />
    </div>
    <div>
        <label>Permisos (JSON):</label>
        <InputTextArea @bind-Value="objRole.Permissions" />
    </div>
    <button type="submit">Actualizar</button>
</EditForm>

@if (successMessage != null)
{
    <div>@successMessage</div>
}

@code {
    // Instancia del rol que se está actualizando
    RolesEntity objRole = new RolesEntity();
    
    // Mensaje para indicar el resultado de la operación
    private string? successMessage;
    
    // ID del rol a actualizar
    [Parameter] public int Id { get; set; }
    
    /*
     * Método que se ejecuta al inicializar el componente.
     * Carga el rol a actualizar.
     */
    protected override async Task OnInitializedAsync()
    {
        // Carga la lista de roles y encuentra el que coincide con el ID
        var roleList = await Task.Run(() => RolesLog.RoleList());
        objRole = roleList.FirstOrDefault(r => r.IdRole == Id) ?? new RolesEntity();
    }
    
    /*
     * Método que se ejecuta al enviar el formulario.
     * Actualiza el rol en la base de datos.
     */
    private void UpdateRole()
    {
        try
        {
            // Llama al método para actualizar el rol en la capa lógica
            RolesLog.UpdateRole(objRole);
            // Muestra un mensaje de éxito
            successMessage = $"El rol '{objRole?.Name}' se actualizó exitosamente!";
            
            //Redirecciona a la lista
            NavManager.NavigateTo("role/list");
        }
        catch (Exception ex)
        {
            // Muestra el mensaje de error en caso de excepción
            successMessage = $"Error al actualizar el rol: {ex.Message}";
        }
    }
}