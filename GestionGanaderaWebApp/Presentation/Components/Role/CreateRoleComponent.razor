@using Logic
@using Model
@inject NavigationManager NavManager

<h3>Crear Rol</h3>

<EditForm Model="objRole" OnValidSubmit="SaveRole" FormName="FrmRole">
    <div>
        <label>Nombre:</label>
        <InputText @bind-Value="objRole.Name" />
    </div>
    <div>
        <label>Permisos (JSON):</label>
        <InputTextArea @bind-Value="objRole.Permissions" />
    </div>
    <button type="submit">Guardar</button>
</EditForm>

@if (successMessage != null)
{
    <div>@successMessage</div>
}

@code {
    // Instancia del rol que se está creando
    RolesEntity objRole = new RolesEntity();
    
    // Mensaje para indicar el resultado de la operación
    private string? successMessage;
    
    /*
     * Método que se ejecuta al enviar el formulario.
     * Guarda el rol en la base de datos.
     */
    private void SaveRole()
    {
        try
        {
            // Llama al método para crear un rol en la capa lógica
            RolesLog.CreateRole(objRole);
            // Muestra un mensaje de éxito
            successMessage = $"El rol '{objRole?.Name}' se guardó exitosamente!";
            
            // Reinicia el formulario para un nuevo registro
            objRole = new RolesEntity();
        }
        catch (Exception ex)
        {
            // Muestra el mensaje de error en caso de excepción
            successMessage = $"Error al guardar el rol: {ex.Message}";
        }
    }
}