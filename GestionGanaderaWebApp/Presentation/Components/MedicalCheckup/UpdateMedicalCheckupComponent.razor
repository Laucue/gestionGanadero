@using Logic
@using Model
@inject NavigationManager NavManager

<h3>Actualizar Medical Checkup</h3>

<EditForm Model="obj" OnValidSubmit="Update" FormName="FrmCheckup">
    <div>
        <label>Animal:</label>
        <InputSelect @bind-Value="obj.IdAnimal">
            <option value="">Seleccione</option>
            @if (animals != null)
            {
                @foreach (var a in animals)
                {
                    <option value="@a.IdAnimal">@a.EarringCode</option>
                }
            }
        </InputSelect>
    </div>
    <div>
        <label>Notas:</label>
        <InputText @bind-Value="obj.Notes" />
    </div>
    <button type="submit">Actualizar</button>
</EditForm>

@if (successMessage != null)
{
    <div>@successMessage</div>
}

@code {
    MedicalCheckupsEntity obj = new MedicalCheckupsEntity();
    private string? successMessage;
    List<AnimalsEntity> animals = new List<AnimalsEntity>();
    [Parameter] public int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        animals = await Task.Run(() => AnimalsLog.AnimalList());
        var list = await Task.Run(() => MedicalCheckupsLog.MedicalCheckupList());
        obj = list.FirstOrDefault(x => x.IdMedicalCheckup == Id) ?? new MedicalCheckupsEntity();
    }

    private void Update()
    {
        try
        {
            MedicalCheckupsLog.UpdateMedicalCheckup(obj);
            successMessage = $"El examen se actualizó exitosamente!";
            NavManager.NavigateTo("medicalcheckup/list");
        }
        catch (Exception ex)
        {
            successMessage = $"Error al actualizar el examen: {ex.Message}";
        }
    }
}
