@using Logic
@using Model
@inject NavigationManager NavManager

<div class="sale-form-container">
    <h3>Crear Venta</h3>

    <EditForm Model="objSale" OnValidSubmit="SaveSale" FormName="FrmSale">
        <div class="form-grid">
            <!-- Primera columna -->
            <div class="form-column">
                <div class="form-group">
                    <label class="form-label">Animal:</label>
                    <InputSelect @bind-Value="objSale.IdAnimal" class="form-select">
                        <option value="">Seleccione un animal</option>
                        @if (animals != null)
                        {
                            @foreach (var animal in animals)
                            {
                                <option value="@animal.IdAnimal">@animal.EarringCode</option>
                            }
                        }
                    </InputSelect>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Fecha de Venta:</label>
                    <InputDate @bind-Value="objSale.SaleDate" class="form-input" />
                </div>
                
                <div class="form-group">
                    <label class="form-label">Nombre del Comprador:</label>
                    <InputText @bind-Value="objSale.BuyerName" class="form-input" placeholder="Ingrese nombre del comprador" />
                </div>
            </div>
            
            <!-- Segunda columna -->
            <div class="form-column">
                <div class="form-group">
                    <label class="form-label">Precio:</label>
                    <InputNumber @bind-Value="objSale.Price" class="form-input" placeholder="0.00" />
                </div>
                
                <div class="form-group">
                    <label class="form-label">Moneda:</label>
                    <InputSelect @bind-Value="objSale.Currency" class="form-select">
                        <option value="COP">COP - Peso Colombiano</option>
                        <option value="USD">USD - Dólar Americano</option>
                        <option value="EUR">EUR - Euro</option>
                        <option value="MXN">MXN - Peso Mexicano</option>
                    </InputSelect>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Peso (Kg):</label>
                    <InputNumber @bind-Value="objSale.WeightKg" class="form-input" placeholder="0.00" />
                </div>
            </div>
        </div>

        <!-- Campo de notas que ocupa ancho completo -->
        <div class="form-group full-width">
            <label class="form-label">Notas:</label>
            <InputTextArea @bind-Value="objSale.Notes" class="form-textarea" placeholder="Observaciones adicionales sobre la venta..." />
        </div>
        
        <div class="form-actions">
            <button type="submit" class="btn-primary">
                <i class="bi bi-check-circle me-2"></i>Guardar
            </button>
        </div>
    </EditForm>

    @if (successMessage != null)
    {
        <div class="alert @(successMessage.Contains("Error") ? "alert-error" : "alert-success")">
            <i class="bi @(successMessage.Contains("Error") ? "bi-exclamation-circle" : "bi-check-circle") me-2"></i>
            @successMessage
        </div>
    }
</div>

<style>
    .sale-form-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    h3 {
        color: #2c3e50;
        margin-bottom: 25px;
        font-weight: 600;
        border-bottom: 2px solid #27ae60;
        padding-bottom: 10px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 25px;
        margin-bottom: 25px;
    }

    .form-column {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-group.full-width {
        grid-column: 1 / -1;
    }

    .form-label {
        font-weight: 600;
        margin-bottom: 8px;
        color: #2c3e50;
        font-size: 14px;
    }

    .form-input, .form-select, .form-textarea {
        padding: 12px 15px;
        border: 1px solid #bdc3c7;
        border-radius: 6px;
        font-size: 14px;
        transition: all 0.3s ease;
        background-color: #fff;
    }

    .form-input:focus, .form-select:focus, .form-textarea:focus {
        outline: none;
        border-color: #27ae60;
        box-shadow: 0 0 0 3px rgba(39, 174, 96, 0.1);
        transform: translateY(-1px);
    }

    .form-textarea {
        min-height: 100px;
        resize: vertical;
        line-height: 1.5;
    }

    .form-actions {
        text-align: right;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #ecf0f1;
    }

    .btn-primary {
        background: linear-gradient(135deg, #27ae60, #229954);
        color: white;
        border: none;
        padding: 12px 25px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 600;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        box-shadow: 0 2px 5px rgba(39, 174, 96, 0.3);
    }

    .btn-primary:hover {
        background: linear-gradient(135deg, #229954, #1e8449);
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(39, 174, 96, 0.4);
    }

    .btn-primary:active {
        transform: translateY(0);
        box-shadow: 0 2px 3px rgba(39, 174, 96, 0.4);
    }

    .alert {
        padding: 15px 20px;
        border-radius: 6px;
        margin-top: 20px;
        display: flex;
        align-items: center;
        font-weight: 500;
    }

    .alert-success {
        background-color: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .alert-error {
        background-color: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }

    .bi {
        font-size: 16px;
    }

    @@media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
            gap: 15px;
        }
        
        .sale-form-container {
            padding: 15px;
        }
        
        .form-actions {
            text-align: center;
        }
    }

    /* Placeholder styling */
    ::deep input::placeholder,
    ::deep select::placeholder,
    ::deep textarea::placeholder {
        color: #95a5a6;
        font-style: italic;
    }

    /* Number input styling */
    ::deep input[type="number"] {
        -moz-appearance: textfield;
    }

    ::deep input[type="number"]::-webkit-outer-spin-button,
    ::deep input[type="number"]::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* Date input styling */
    ::deep input[type="date"] {
        color: #2c3e50;
    }
</style>

@code {
    // Instancia de la venta que se está creando
    SalesEntity objSale = new SalesEntity();
    
    // Mensaje para indicar el resultado de la operación
    private string? successMessage;
    
    // Lista de animales disponibles para seleccionar
    List<AnimalsEntity> animals = new List<AnimalsEntity>();
    
    /*
     * Método que se ejecuta al inicializar el componente.
     * Carga la lista de animales de forma asíncrona.
     */
    protected override async Task OnInitializedAsync()
    {
        // Carga asíncrona de animales
        animals = await Task.Run(() => AnimalsLog.AnimalList());
        objSale.SaleDate = DateTime.Now;
        objSale.Currency = "COP";
    }
    
    /*
     * Método que se ejecuta al enviar el formulario.
     * Guarda la venta en la base de datos.
     */
    private void SaveSale()
    {
        try
        {
            // Llama al método para crear una venta en la capa lógica
            SalesLog.CreateSale(objSale);
            // Muestra un mensaje de éxito
            successMessage = "¡La venta se guardó exitosamente!";
            
            // Reinicia el formulario para un nuevo registro
            objSale = new SalesEntity();
            objSale.SaleDate = DateTime.Now;
            objSale.Currency = "COP";
        }
        catch (Exception ex)
        {
            // Muestra el mensaje de error en caso de excepción
            successMessage = $"Error al guardar la venta: {ex.Message}";
        }
    }
}