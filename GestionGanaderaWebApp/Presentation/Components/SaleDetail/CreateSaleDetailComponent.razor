@using Logic
@using Model
@inject NavigationManager NavManager

<h3>Crear Sale Detail</h3>

<EditForm Model="obj" OnValidSubmit="Save" FormName="FrmSaleDetail">
    <div>
        <label>Sale Id:</label>
        <InputSelect @bind-Value="obj.IdSale">
            <option value="">Seleccione</option>
            @if (sales != null)
            {
                @foreach (var s in sales)
                {
                    <option value="@s.IdSale">@s.IdSale - @s.IdAnimal</option>
                }
            }
        </InputSelect>
    </div>
    <div>
        <label>Monto:</label>
        <InputNumber @bind-Value="obj.Amount" />
    </div>
    <button type="submit">Guardar</button>
</EditForm>

@if (successMessage != null)
{
    <div>@successMessage</div>
}

@code {
    SaleDetailsEntity obj = new SaleDetailsEntity();
    private string? successMessage;
    List<SalesEntity> sales = new List<SalesEntity>();

    protected override async Task OnInitializedAsync()
    {
        sales = await Task.Run(() => SalesLog.SaleList());
    }

    private void Save()
    {
        try
        {
            SaleDetailsLog.CreateSaleDetail(obj);
            successMessage = $"El detalle de venta se guardó exitosamente!";
            obj = new SaleDetailsEntity();
        }
        catch (Exception ex)
        {
            successMessage = $"Error al guardar el detalle de venta: {ex.Message}";
        }
    }
}
