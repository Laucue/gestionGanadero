@using Logic
@using Model
@inject NavigationManager NavManager

<h3>Crear Especie</h3>

<EditForm Model="objSpecies" OnValidSubmit="SaveSpecies" FormName="FrmSpecies">
    <div>
        <label>Nombre:</label>
        <InputText @bind-Value="objSpecies.Name" />
    </div>
    <button type="submit">Guardar</button>
</EditForm>

@if (successMessage != null)
{
    <div>@successMessage</div>
}

@code {
    // Instancia de la especie que se está creando
    PastureTypesEntity objSpecies = new PastureTypesEntity();
    
    // Mensaje para indicar el resultado de la operación
    private string? successMessage;
    
    /*
     * Método que se ejecuta al enviar el formulario.
     * Guarda la especie en la base de datos.
     */
    private void SaveSpecies()
    {
        try
        {
            // Llama al método para crear una especie en la capa lógica
            PastureTypesLog.CreateSpecies(objSpecies);
            // Muestra un mensaje de éxito
            successMessage = $"La especie '{objSpecies?.Name}' se guardó exitosamente!";
            
            // Reinicia el formulario para un nuevo registro
            objSpecies = new PastureTypesEntity();
        }
        catch (Exception ex)
        {
            // Muestra el mensaje de error en caso de excepción
            successMessage = $"Error al guardar la especie: {ex.Message}";
        }
    }
}