@using Logic
@using Model
@inject NavigationManager NavManager

<h3>Crear Registro de Salud</h3>

<EditForm Model="objHealthRecord" OnValidSubmit="SaveHealthRecord" FormName="FrmHealthRecord">
    <div>
        <label>Animal:</label>
        <InputSelect @bind-Value="objHealthRecord.IdAnimal">
            <option value="">Seleccione</option>
            @if (animals != null)
            {
                @foreach (var animal in animals)
                {
                    <option value="@animal.IdAnimal">@animal.EarringCode</option>
                }
            }
        </InputSelect>
    </div>
    <div>
        <label>Tipo de Evento:</label>
        <InputSelect @bind-Value="objHealthRecord.EventType">
            <option value="">Seleccione</option>
            <option value="VACCINE">VACCINE</option>
            <option value="TREATMENT">TREATMENT</option>
            <option value="DISEASE">DISEASE</option>
            <option value="CHECKUP">CHECKUP</option>
        </InputSelect>
    </div>
    <div>
        <label>Fecha del Evento:</label>
        <InputDate @bind-Value="objHealthRecord.EventDate" />
    </div>
    <div>
        <label>Diagnóstico:</label>
        <InputTextArea @bind-Value="objHealthRecord.Diagnosis" />
    </div>
    <div>
        <label>Tratamiento:</label>
        <InputTextArea @bind-Value="objHealthRecord.Treatment" />
    </div>
    <div>
        <label>Medicación:</label>
        <InputText @bind-Value="objHealthRecord.Medication" />
    </div>
    <div>
        <label>Dosis:</label>
        <InputNumber @bind-Value="objHealthRecord.Dose" />
    </div>
    <div>
        <label>Unidad de Dosis:</label>
        <InputText @bind-Value="objHealthRecord.DoseUnit" />
    </div>
    <div>
        <label>Veterinario:</label>
        <InputText @bind-Value="objHealthRecord.Veterinarian" />
    </div>
    <div>
        <label>Vacuna:</label>
        <InputSelect @bind-Value="objHealthRecord.IdVaccine">
            <option value="">Seleccione</option>
            @if (vaccines != null)
            {
                @foreach (var vaccine in vaccines)
                {
                    <option value="@vaccine.IdVaccine">@vaccine.Name</option>
                }
            }
        </InputSelect>
    </div>
    <div>
        <label>Lote:</label>
        <InputText @bind-Value="objHealthRecord.Batch" />
    </div>
    <div>
        <label>Próxima Fecha de Refuerzo:</label>
        <InputDate @bind-Value="objHealthRecord.NextBoosterDate" />
    </div>
    <div>
        <label>Notas:</label>
        <InputTextArea @bind-Value="objHealthRecord.Notes" />
    </div>
    <button type="submit">Guardar</button>
</EditForm>

@if (successMessage != null)
{
    <div>@successMessage</div>
}

@code {
    // Instancia del registro de salud que se está creando
    HealthRecordsEntity objHealthRecord = new HealthRecordsEntity();
    
    // Mensaje para indicar el resultado de la operación
    private string? successMessage;
    
    // Listas para los selects
    List<AnimalsEntity> animals = new List<AnimalsEntity>();
    List<VaccinesEntity> vaccines = new List<VaccinesEntity>();
    
    /*
     * Método que se ejecuta al inicializar el componente.
     * Carga las listas necesarias de forma asíncrona.
     */
    protected override async Task OnInitializedAsync()
    {
        // Carga asíncrona de datos
        animals = await Task.Run(() => AnimalsLog.AnimalList());
        vaccines = await Task.Run(() => VaccinesLog.VaccineList());
        objHealthRecord.EventDate = DateTime.Now;
    }
    
    /*
     * Método que se ejecuta al enviar el formulario.
     * Guarda el registro de salud en la base de datos.
     */
    private void SaveHealthRecord()
    {
        try
        {
            // Llama al método para crear un registro de salud en la capa lógica
            HealthRecordsLog.CreateHealthRecord(objHealthRecord);
            // Muestra un mensaje de éxito
            successMessage = "El registro de salud se guardó exitosamente!";
            
            // Reinicia el formulario para un nuevo registro
            objHealthRecord = new HealthRecordsEntity();
            objHealthRecord.EventDate = DateTime.Now;
        }
        catch (Exception ex)
        {
            // Muestra el mensaje de error en caso de excepción
            successMessage = $"Error al guardar el registro de salud: {ex.Message}";
        }
    }
}