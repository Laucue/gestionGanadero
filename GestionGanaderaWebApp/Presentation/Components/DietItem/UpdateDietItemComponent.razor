
@using Logic
@using Model
@inject NavigationManager NavManager

<h3>Actualizar Item de Dieta</h3>

<EditForm Model="objDietItem" OnValidSubmit="UpdateDietItem" FormName="FrmDietItem">
    <div>
        <label>Dieta:</label>
        <InputSelect @bind-Value="objDietItem.IdDiet">
            <option value="">Seleccione</option>
            @if (diets != null)
            {
                @foreach (var diet in diets)
                {
                    <option value="@diet.IdDiet">@diet.Name</option>
                }
            }
        </InputSelect>
    </div>
    <div>
        <label>Alimento:</label>
        <InputText @bind-Value="objDietItem.Food" />
    </div>
    <div>
        <label>Cantidad Diaria (Kg):</label>
        <InputNumber @bind-Value="objDietItem.DailyAmountKg" />
    </div>
    <button type="submit">Actualizar</button>
</EditForm>

@if (successMessage != null)
{
    <div>@successMessage</div>
}

@code {
    // Instancia del item de dieta que se está actualizando
    DietItemsEntity objDietItem = new DietItemsEntity();
    
    // Mensaje para indicar el resultado de la operación
    private string? successMessage;
    
    // Lista de dietas disponibles para seleccionar
    List<DietsEntity> diets = new List<DietsEntity>();
    
    // ID del item de dieta a actualizar
    [Parameter] public int Id { get; set; }
    
    /*
     * Método que se ejecuta al inicializar el componente.
     * Carga el item de dieta a actualizar y la lista de dietas.
     */
    protected override async Task OnInitializedAsync()
    {
        // Carga asíncrona de items de dieta y dietas
        var dietItemList = await Task.Run(() => DietItemsLog.DietItemList());
        diets = await Task.Run(() => DietsLog.DietList());
        objDietItem = dietItemList.FirstOrDefault(di => di.IdItem == Id) ?? new DietItemsEntity();
    }
    
    /*
     * Método que se ejecuta al enviar el formulario.
     * Actualiza el item de dieta en la base de datos.
     */
    private void UpdateDietItem()
    {
        try
        {
            // Llama al método para actualizar el item de dieta en la capa lógica
            DietItemsLog.UpdateDietItem(objDietItem);
            // Muestra un mensaje de éxito
            successMessage = $"El item de dieta '{objDietItem?.Food}' se actualizó exitosamente!";
            
            //Redirecciona a la lista
            NavManager.NavigateTo("dietitem/list");
        }
        catch (Exception ex)
        {
            // Muestra el mensaje de error en caso de excepción
            successMessage = $"Error al actualizar el item de dieta: {ex.Message}";
        }
    }
}